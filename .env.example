# ─── Platform ──────────────────────────────────────────
# APP_ENV: production | development | test
# docker-compose overrides this to "production" inside the container, which
# triggers `alembic upgrade head` in the FastAPI lifespan handler.
APP_ENV=development

# Long, random string. Used for JWT signing. Rotate invalidates all sessions.
APP_SECRET_KEY=change-me-to-a-long-random-string

# Bind address/port for uvicorn. Container always binds 0.0.0.0:8000; these
# are only used when running the backend outside Docker.
APP_HOST=0.0.0.0
APP_PORT=8000

# ─── Instructor admin account (bootstrap) ──────────────
# Created on first startup if no user with this email exists. Updating the
# password here after first boot does NOT rotate it - change it via the API.
ADMIN_EMAIL=admin@insec.ml
ADMIN_PASSWORD=change-me-strong-password

# ─── Database ──────────────────────────────────────────
# Local (outside Docker): sqlite:///./data/insec.db
# Docker Compose overrides this to PostgreSQL automatically.
DATABASE_URL=sqlite:///./data/insec.db

# ─── Public URL ────────────────────────────────────────
# Used to build invite links emailed/shared with students, and added to the
# CORS allow-list. No trailing slash.
PUBLIC_BASE_URL=http://localhost

# ─── Invite settings ───────────────────────────────────
# How long a single-use student invite token is valid for (hours).
INVITE_TOKEN_TTL_HOURS=168  # 7 days

# ─── File storage ──────────────────────────────────────
# Where WireGuard .conf files returned from Ludus are cached for download.
# Host:      ./data/configs
# Container: /app/data/configs  (set automatically by compose)
CONFIG_STORAGE_DIR=./data/configs

# ─── Ludus server(s) ───────────────────────────────────
# Primary Ludus instance the platform talks to.
#
# TARGETING LUDUS v1 (1.11.x) - TWO PORTS:
#   Ludus v1 splits its API across two ports:
#     * :8080  (user API, all interfaces) - ranges, snapshots, testing,
#              range-access, templates, ansible, AND user reads/wireguard.
#              Admin actions work here via ?userID= impersonation with an
#              admin key - EXCEPT creating/deleting users (403 here).
#     * :8081  (admin API, 127.0.0.1 only) - user CREATE/DELETE. This is the
#              only port that accepts POST/DELETE /user. It rejects range ops
#              ("can only be used for user actions").
#
#   This platform creates a Ludus user per student, so it needs BOTH:
#     LUDUS_DEFAULT_URL       -> the :8080 user API
#     LUDUS_DEFAULT_ADMIN_URL -> the :8081 admin API (used only for user
#                                create/delete). Omit on newer Ludus where a
#                                single URL serves everything.
#
#   :8081 is localhost-only on the Ludus host, so run this platform ON the
#   host, or forward the port to where it runs, e.g. on a jump host that can
#   reach it:  ssh -N -L 0.0.0.0:18081:127.0.0.1:8081 root@<ludus-host>
#   then set LUDUS_DEFAULT_ADMIN_URL=https://<jump-host>:18081
#
#   Use an ADMIN user's API key (e.g. the root/admin Ludus user).
LUDUS_DEFAULT_URL=https://<ludus-host>:8080
LUDUS_DEFAULT_ADMIN_URL=https://127.0.0.1:8081
LUDUS_DEFAULT_API_KEY=your-ludus-admin-api-key-here
# Set to true only if the Ludus server presents a trusted cert. Lab/self-
# signed deployments should leave this false.
LUDUS_DEFAULT_VERIFY_TLS=false

# Additional Ludus instances: LUDUS_<NAME>_URL, LUDUS_<NAME>_API_KEY,
# LUDUS_<NAME>_VERIFY_TLS (e.g. LUDUS_RESEARCH_URL=...).

# ─── Reverse proxy / TLS (production only) ───────────────
# Optional. Local dev uses frontend nginx on port 80 (no Caddy required).
# Set DOMAIN for production HTTPS via Caddy or another reverse proxy.
DOMAIN=

# ─── Postgres ─────────────────────────────────────────────
# Password for the Postgres container. Change for production.
POSTGRES_PASSWORD=insec-dev-password

# Seed a starter pack of Ludus v1 range configs into Lab Templates on first
# boot (once per seed version). Set false to start empty.
SEED_LAB_TEMPLATES=true

# ─── Login authentication against Ludus/Proxmox ─────────
# Let instructors log in with their Ludus userID (or Proxmox username) +
# Proxmox password, validated against the Proxmox ticket API. Local app
# accounts still work (tried first).
LUDUS_AUTH_ENABLED=true
# Only Ludus admin users may log in. Set false to allow any valid Ludus user.
LUDUS_AUTH_ADMINS_ONLY=true
# Proxmox base URL for the ticket check. If unset, derived from the Ludus host
# on port 8006 (e.g. https://<ludus-host>:8006).
# PROXMOX_URL=https://192.168.0.191:8006
PROXMOX_REALM=pam
PROXMOX_VERIFY_TLS=false
