# ─── Platform ──────────────────────────────────────────
# APP_ENV: production | development | test
# docker-compose overrides this to "production" inside the container, which
# triggers `alembic upgrade head` in the FastAPI lifespan handler.
APP_ENV=development

# Long, random string. Used for JWT signing. Rotate invalidates all sessions.
APP_SECRET_KEY=change-me-to-a-long-random-string

# Bind address/port for uvicorn. Container always binds 0.0.0.0:8000; these
# are only used when running the backend outside Docker.
APP_HOST=0.0.0.0
APP_PORT=8000

# ─── Instructor admin account (bootstrap) ──────────────
# Created on first startup if no user with this email exists. Updating the
# password here after first boot does NOT rotate it - change it via the API.
ADMIN_EMAIL=admin@insec.ml
ADMIN_PASSWORD=change-me-strong-password

# ─── Database ──────────────────────────────────────────
# Local (outside Docker): sqlite:///./data/insec.db
# Docker Compose overrides this to PostgreSQL automatically.
DATABASE_URL=sqlite:///./data/insec.db

# ─── Public URL ────────────────────────────────────────
# Used to build invite links emailed/shared with students, and added to the
# CORS allow-list. No trailing slash.
PUBLIC_BASE_URL=http://localhost

# ─── Invite settings ───────────────────────────────────
# How long a single-use student invite token is valid for (hours).
INVITE_TOKEN_TTL_HOURS=168  # 7 days

# ─── File storage ──────────────────────────────────────
# Where WireGuard .conf files returned from Ludus are cached for download.
# Host:      ./data/configs
# Container: /app/data/configs  (set automatically by compose)
CONFIG_STORAGE_DIR=./data/configs

# ─── Ludus server(s) ───────────────────────────────────
# Primary Ludus instance the platform talks to.
#
# TARGETING LUDUS v1 (1.11.x):
#   This platform creates/deletes a Ludus user per student. On Ludus v1 those
#   admin operations (POST/DELETE /user) are served ONLY by the ADMIN API on
#   127.0.0.1:8081 (they return 403 on the :8080 user API). Range, snapshot,
#   testing and range-access operations DO work on :8080 with an admin key +
#   ?userID= impersonation, but user management does not.
#
#   Therefore point LUDUS_DEFAULT_URL at the admin API (:8081). Because :8081
#   is bound to localhost on the Ludus host, run this platform ON the Ludus
#   host, or forward the port to wherever it runs, e.g.:
#       ssh -N -L 8081:127.0.0.1:8081 root@<ludus-host>
#   then set LUDUS_DEFAULT_URL=https://127.0.0.1:8081
#
#   Use an ADMIN user's API key (e.g. the root/admin Ludus user).
LUDUS_DEFAULT_URL=https://127.0.0.1:8081
LUDUS_DEFAULT_API_KEY=your-ludus-admin-api-key-here
# Set to true only if the Ludus server presents a trusted cert. Lab/self-
# signed deployments should leave this false.
LUDUS_DEFAULT_VERIFY_TLS=false

# Additional Ludus instances: LUDUS_<NAME>_URL, LUDUS_<NAME>_API_KEY,
# LUDUS_<NAME>_VERIFY_TLS (e.g. LUDUS_RESEARCH_URL=...).

# ─── Reverse proxy / TLS (production only) ───────────────
# Optional. Local dev uses frontend nginx on port 80 (no Caddy required).
# Set DOMAIN for production HTTPS via Caddy or another reverse proxy.
DOMAIN=

# ─── Postgres ─────────────────────────────────────────────
# Password for the Postgres container. Change for production.
POSTGRES_PASSWORD=insec-dev-password
