# Shared route definitions for backend + frontend.
(common) {
	# API + health + invite → backend
	handle /api/* {
		reverse_proxy backend:8000
	}
	handle /health {
		reverse_proxy backend:8000
	}
	handle /invite/* {
		reverse_proxy backend:8000
	}

	# Everything else → frontend
	handle {
		reverse_proxy frontend:3000
	}
}

# Plain HTTP - works locally without self-signed cert warnings.
# For production HTTPS, set DOMAIN in .env and replace this block with:
#   {$DOMAIN} { import common }
:80 {
	import common
}
